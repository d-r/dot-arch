#!/usr/bin/env nu

# Manage system packages.
def main [] {
    help main
}

# Install package(s).
def --wrapped "main in" [...$args] {
    let $pkgs = if ($args | is-empty) {
        yay -Slq
            | fzf --multi --preview 'yay -Si {}' --preview-window 'down:50%:wrap'
            | lines
    } else {
        $args
    }

    if ($pkgs | is-empty) {
        print "No packages selected."
        return
    }

    yay -Syu --needed ...$pkgs
}

# Uninstall package(s).
def --wrapped "main un" [...$args] {
    let $pkgs = if ($args | is-empty) {
        # -Qe = list packages that were explicitly installed
        yay -Qeq
            | fzf --multi --preview 'yay -Si {}' --preview-window 'down:50%:wrap'
            | lines
    } else {
        $args
    }

    if ($pkgs | is-empty) {
        print "No packages selected."
        return
    }

    yay -Rns ...$pkgs
}

# Update outdated packages.
def "main up" [] {
    yay
}

# List outdated packages.
def "main out" [] {
    yay -Qu
}

# Clear cache.
def "main cc" [] {
    sudo rm -rf ~/.cache/yay/*
}

# Dump Pacmanfile.
def "main dump" [] {
    pacmanfile dump
}

# Show Pacmanfile.
def "main file" [] {
    bat ~/.config/pacmanfile/pacmanfile-dumped.txt
}

# List packages no longer required as dependencies.
def "main orphans" [] {
    yay -Qdtq | lines
}

# Uninstall orphans.
def "main clean" [] {
    main un ...(main orphans)
}

# Get information about a package.
def "main info" [$pk] {
    yay -Si $pk
}
