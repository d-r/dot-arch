#!/usr/bin/env nu

const $BROWSER = "brave-browser.desktop"
const $DOC_VIEWER = "zathura.desktop"
const $IMAGE_VIEWER = "imv.desktop"
const $AUDIO_PLAYER = "mpv.desktop"
const $VIDEO_PLAYER = "mpv.desktop"

# Default browser
xdg-settings set default-web-browser $BROWSER
xdg-mime default $BROWSER x-scheme-handler/http
xdg-mime default $BROWSER x-scheme-handler/https

# Documents
xdg-mime default $DOC_VIEWER application/pdf
xdg-mime default $DOC_VIEWER application/epub+zip

# Images
xdg-mime default $IMAGE_VIEWER image/png
xdg-mime default $IMAGE_VIEWER image/jpeg
xdg-mime default $IMAGE_VIEWER image/gif
xdg-mime default $IMAGE_VIEWER image/webp
xdg-mime default $IMAGE_VIEWER image/bmp
xdg-mime default $IMAGE_VIEWER image/tiff

# Audio
xdg-mime default $AUDIO_PLAYER audio/flac
xdg-mime default $AUDIO_PLAYER audio/x-flac
xdg-mime default $AUDIO_PLAYER audio/mp3
xdg-mime default $AUDIO_PLAYER audio/x-mp3
xdg-mime default $AUDIO_PLAYER audio/mp4
xdg-mime default $AUDIO_PLAYER audio/aac
xdg-mime default $AUDIO_PLAYER audio/x-aac

# Videos
xdg-mime default $VIDEO_PLAYER video/mp4
xdg-mime default $VIDEO_PLAYER video/x-msvideo
xdg-mime default $VIDEO_PLAYER video/x-matroska
xdg-mime default $VIDEO_PLAYER video/x-flv
xdg-mime default $VIDEO_PLAYER video/x-ms-wmv
xdg-mime default $VIDEO_PLAYER video/mpeg
xdg-mime default $VIDEO_PLAYER video/ogg
xdg-mime default $VIDEO_PLAYER video/webm
xdg-mime default $VIDEO_PLAYER video/quicktime
xdg-mime default $VIDEO_PLAYER video/3gpp
xdg-mime default $VIDEO_PLAYER video/3gpp2
xdg-mime default $VIDEO_PLAYER video/x-ms-asf
xdg-mime default $VIDEO_PLAYER video/x-ogm+ogg
xdg-mime default $VIDEO_PLAYER video/x-theora+ogg
xdg-mime default $VIDEO_PLAYER application/ogg

# GTK
gsettings set org.gnome.desktop.interface color-scheme prefer-dark
gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark
gsettings set org.gnome.desktop.interface icon-theme Adwaita
gsettings set org.gnome.desktop.interface cursor-theme Adwaita
gsettings set org.gnome.desktop.interface cursor-size 24
