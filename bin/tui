#!/usr/bin/env nu

use kit *

def main [] {}

def "main save-url" [$url] {
    let $links = (open? $env.DOT_LINK_FILE {})
    let $key = ($links | key-of $url | default "")

    let $key = (gum input --placeholder $"Key for ($url)" --value $key)

    if ($key | is-not-empty) {
        ($links | upsert $key $url) | to yaml | save -f $env.DOT_LINK_FILE
        notify-send $'Bookmark "($key)" saved'
    }
}

def "main pick-link" [] {
    xdg-open (pick-link)
}

def "main pick-snippet" [] {
    wl-copy (pick-snippet)
}

def "main pick-link-into" [$file] {
    (pick-link) o> $file
}

def "main pick-dir" [] {
    cd
    wm spawn kitty --app-id "yazi" -- yazi (fd -td | fzf)
}

def "main pick-project" [] {
    ide (pick-project)
}

def "main todo" [] {
    taskwarrior-tui
}

#-------------------------------------------------------------------------------

def pick-snippet [] {
    let $snippets = (open? $env.DOT_SNIPPET_FILE {})
    let $menu = ($snippets | kv | table-str --no-headers)
    ($menu | fzf
        -d "\t"
        -n 1 # key
        --accept-nth 2 # value
        --bind "ctrl-e:become(edit-snippets)"
        --header "ctrl+e to edit"
    )
}

def pick-link [] {
    let $links = (open? $env.DOT_LINK_FILE {})
    let $menu = ($links | kv | table-str --no-headers)
    ($menu | fzf
        -d "\t"
        -n 1 # name
        --accept-nth 2 # url
        --bind "ctrl-e:become(edit-links)"
        --header "ctrl+e to edit"
    )
}

def pick-project [] {
    cd $env.DOT_REPO_DIR
    let $dir = (fd -td --follow | fzf)
    ($dir | path expand )
}
