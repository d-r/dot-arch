#!/usr/bin/env nu

use ~/dot/nu/all.nu *

const $BOOKMARKS_FILE = ('~/churn/bookmarks.toml' | path expand)

export def main [] {
    main open
}

export def "main open" [] {
    cx browser (main pick)
}

export def "main pick" [] {
    (main read | pick-item)
}

export def "main save" [$url] {
    let $marks = (main read)
    let $key = ($marks | key-of $url) | default ""

    let $key = gum input --placeholder $"Key for ($url)" --value $key

    if ($key | is-not-empty) {
        main write ($marks | upsert $key $url)
        notify-send $'Bookmark "($key)" saved'
    }
}

export def "main read" [] {
    open $BOOKMARKS_FILE
}

export def "main write" [$marks] {
    $marks | to toml | save -f $BOOKMARKS_FILE
}

# QUTEBROWSER

const $QB_URL_FILE = "/tmp/qb-url"

export def "main qb-open" [] {
    (main pick) o> $QB_URL_FILE
}

export def "main qb-url-file" [] {
    $QB_URL_FILE
}
