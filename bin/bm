#!/usr/bin/env nu

use ~/dot/nu/all.nu *

const $BOOKMARKS_FILE = ('~/churn/bookmarks.toml' | path expand)
const $QB_URL_FILE = "/tmp/qb-url"

export def main [] {
    main open
}

export def "main open" []: nothing -> nothing {
    # Using `wm spawn` here makes the terminal window close quicker.
    wm spawn xdg-open (main read | pick-item)
}

export def "main qb-open" []: nothing -> nothing {
    (main read | pick-item) o> $QB_URL_FILE
}

export def "main save" [$url: string]: nothing -> nothing {
    let $marks = main read
    let $key = ($marks | key-of $url) | default ""

    let $key = gum input --placeholder $"Key for ($url)" --value $key

    if ($key | is-not-empty) {
        ($marks | upsert $key $url) | main write
        notify-send $'Bookmark "($key)" saved'
    }
}

export def "main read" []: nothing -> record {
    open $BOOKMARKS_FILE
}

export def "main write" []: record -> nothing {
    $in | to toml | save -f $BOOKMARKS_FILE
}
