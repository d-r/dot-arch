#!/usr/bin/env bash

# To make this work:
#
# yay -S inotify-tools
# systemctl --user daemon-reload
# systemctl --user enable --now waybar-watcher.service

CONFIG_DIR="$HOME/.config/waybar"

while inotifywait -e close_write "$CONFIG_DIR"/config.jsonc "$CONFIG_DIR"/style.css; do
    pkill -SIGUSR2 waybar
done
