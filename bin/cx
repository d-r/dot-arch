#!/usr/bin/env nu

use ~/dot/nu/all.nu *

# Context
def main [] {
    help main
}

# Spawn bookmark picker
def "main pick-bookmark" [] {
    tui bookmarks -- bm open
}

# Spawn project picker
def "main pick-project" [] {
    tui projects -- dev open
}

# If there is a URL inside the clipboard, save it as a bookmark
def "main save-clipped-url" [] {
    let $s = (wl-paste)
    if ($s | is-url) {
        tui save-url -- bm save $s
    } else if ($s | is-empty) {
        notify-send "Clipboard is empty"
    } else {
        notify-send "Clipboard contents is not a URL"
    }
}

# Spawn a browser
def "main browser" [$url = ""] {
    let $name = (wm ws-name)
    if $name == "web" {
        firefox $url
    } else {
        qb $name $url
    }
}

# Spawn a terminal and optionally run a command inside of it
def --wrapped "main term" [...$cmd] {
    footclient -D (main cwd) ...$cmd
}

# If the focused window is a terminal, close it and spawn another term in its place
def "main respawn-term" [] {
    let $w = (wm focused-window)
    if ($w | is-not-empty) and $w.app_id == "footclient" {
        wm spawn footclient -D (main cwd)
        wm close-window $w.id
    }
}

# Get the current working directory for the focused workspace
export def "main cwd" [] {
    match (wm ws-name) {
        web => "~/dl"
        dot => "~/dot"
        dev => "~/lab"
        brn => "~/brain"
        snd => "~/snd"
        _ => "~"
    }
    | path expand
}
