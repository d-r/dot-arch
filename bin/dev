#!/usr/bin/env nu

use ~/dot/nu/all.nu *

# Development
def main [] {
    main open
}

# Open a repo
def "main open" [] {
    ide (main pick)
}

# Pick a repo
def "main pick" [] {
    (main repos) | fzf
}

# List repos
def "main repos" [] {
    [
        (repo ~/dot)
        (repo ~/churn)
        (repos-in ~/src)
        (repos-in ~/lab)
    ] | flatten | join-lines
}

#-------------------------------------------------------------------------------

def repo [$dir] {
    [$dir]
}

def repos-in [$dir] {
    ls ($dir | path expand) | where type == dir | each { $in.name | shorten-home }
}

def ide [$dir] {
    wm spawn code ($dir | path expand)
}
