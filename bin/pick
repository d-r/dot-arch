#!/usr/bin/env nu

use dot *

# Pick a thing.
def main [] {
    help main
}

# Pick a link.
def "main link" [] {
    let $links = (open $env.DOT_LINK_FILE)
    let $menu = ($links | kv | table-str --no-headers)
    ($menu | fzf
        -d "\t"
        -n 1 # name
        --accept-nth 2 # url
        --bind "ctrl-e:become(pick.edit-bookmarks)"
        --header "ctrl+e to edit"
    )
}

# Pick a git repository.
def "main repo" [] {
    let $repos = $env.DOT_REPOS | each { repo $in }
    let $menu = $repos | table-str --no-headers
    ($menu | fzf
        -d "\t"
        -n 1 # name
        --with-nth 1
        --accept-nth 2 # dir
    )
}

#-------------------------------------------------------------------------------

def repo [$dir: path]: nothing -> record {
    {name: ($dir | path basename), dir: $dir}
}
