#!/usr/bin/env nu

use ./nu/kit *
use std/log

const $SOURCE_DIR = ("~/dot/src" | path expand --no-symlink)

# Install
def "main" [] {
    main shell
    main links
    main keyd
}

# Install keyd config
def "main keyd" [] {
    sudo mkdir -p /etc/keyd
    sudo cp -fv (source-path keyd.conf) /etc/keyd/default.conf
    sudo keyd reload
}

# Install symlinks
def "main links" [] {
    cd ~/.config

    link task/taskrc taskrc
    link fuzzel/fuzzel.ini fuzzel.ini
    link tmux/tmux.conf tmux.conf
    link mpd/mpd.conf mpd.conf
    link waybar/config.jsonc waybar.jsonc
    link waybar/style.css waybar.css
    link mako/config mako.ini
    link yazi/yazi.toml yazi.toml
    link yazi/theme.toml yazi.theme.toml
    link tealdeer/config.toml tealdeer.toml
    link wlr-which-key/config.yaml wlr-which-key.yaml
    link systemd/user/waybar-watcher.service systemd/waybar-watcher.service

    link git
    link nvim
    link helix
    link niri
    link kitty
    link foot
    link qutebrowser
}

# Install shell config
def "main shell" [] {
    let $home = $nu.home-dir
    let $lang = "en_IE.UTF-8"

    let $path = [
        $"($home)/dot/bin"
        $"($home)/.cargo/bin"
        $"($home)/lab"
    ]

    let $vars = {
        # https://wiki.archlinux.org/title/XDG_Base_Directory
        XDG_CONFIG_HOME: $"($home)/.config"
        XDG_CACHE_HOME: $"($home)/.cache"
        XDG_DATA_HOME: $"($home)/.local/share"
        XDG_STATE_HOME: $"($home)/.local/state"

        # https://wiki.archlinux.org/title/XDG_user_directories
        XDG_DOWNLOAD_DIR: $"($home)/dl"
        XDG_DOCUMENTS_DIR: $"($home)/doc"
        XDG_MUSIC_DIR: $"($home)/media/audio/releases"
        XDG_VIDEOS_DIR: $"($home)/media/video" # ?
        XDG_PICTURES_DIR: $"($home)/images" # ?
        XDG_DESKTOP_DIR: $"($home)/tmp" # ?

        LANG: $lang
        LC_ALL: $lang
        LC_COLLATE: $lang
        LC_CTYPE: $lang
        LC_MESSAGES: $lang
        LC_MONETARY: $lang
        LC_NUMERIC: $lang
        LC_TIME: $lang

        EDITOR: "micro"
        MANPAGER: "nvim +Man!"
        FZF_DEFAULT_OPTS: "--style=minimal --reverse"
        SKIM_DEFAULT_OPTIONS: "--reverse"
        FD_OPTS: "--hidden"
    }

    # nushell
    mkdir ~/.config/nushell
    do {
        cd ~/.config/nushell

        rm config.nu
        cp -v ~/dot/src/nushell.nu config.nu
        (nushell-env $path $vars) | save -a config.nu
    }

    # zsh
    do {
        cd

        rm .zshenv
        rm .zshrc
        (zsh-env $path $vars) | save .zshenv
        link .zshrc zshrc
    }
}

#-------------------------------------------------------------------------------
# CODE GENERATION

def zsh-env [$path, $vars] {
    let $p = $path | each { echo $'export PATH="$PATH:($in)"' }
    let $v = $vars | items { |k, v| echo $'export ($k)="($v)"' }
    ($p ++ $v) | str join "\n"
}

def nushell-env [$path, $vars] {
    let $p = $path | to nuon --indent 4
    let $v = $vars | to nuon --indent 4
    [
        ""
        $'$env.path ++= ($p)'
        ""
        $"load-env ($v)"
        ""
    ]
    | str join "\n"
}

#-------------------------------------------------------------------------------
# LINKING

def link [$target, $source = ""] {
    let $source = if ($source | is-empty) {
        $target
    } else {
        $source
    }

    let $source = (source-path $source)
    if not ($source | path exists) {
        log warning $"Path `($source)` does not exist; skipping"
        return;
    }

    let $dir = $target | path dirname
    if ($dir | is-symlink) {
        rm -v $dir
    }

    mktrail $target
    ln -sfnT $source $target

    let $target = $target | path expand --no-symlink | shorten-home
    let $source = $source | shorten-home
    print $"($target) -> ($source)"
}

def source-path [...$args] {
    [$SOURCE_DIR] | append $args | path join
}
