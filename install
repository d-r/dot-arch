#!/usr/bin/env nu

use ./nu/kit *
use std/log

const $CONFIG_DIR = ("~/dot/cfg" | path expand --no-symlink)

def "main" [] {
    main zsh
    main configs
    main user-dirs
    main systemd
    main keyd
}

def "main zsh" [] {
    cd

    link .zshrc zshrc
    link .zshenv zshenv
}

def "main configs" [] {
    cd ~/.config

    link task/taskrc taskrc
    link fuzzel/fuzzel.ini fuzzel.ini
    link tmux/tmux.conf tmux.conf
    link mpd/mpd.conf mpd.conf
    link waybar/config.jsonc waybar.jsonc
    link waybar/style.css waybar.css
    link mako/config mako.ini
    link yazi/yazi.toml yazi.toml
    link tealdeer/config.toml tealdeer.toml
    link wlr-which-key/config.yaml wlr-which-key.yaml

    link git
    link nvim
    link helix
    link niri
    link kitty
    link foot
    link qutebrowser
}

def "main user-dirs" [] {
    cd ~/.config

    link user-dirs.dirs
    link user-dirs.locale

    xdg-user-dirs-update
}

def "main systemd" [] {
    systemctl --user daemon-reload

    mkcd ~/.config/systemd/user

    for $source in (glob (cfg-path "systemd" "*.service")) {
        let $target = ($source | path basename)
        
        ln -sfv $source ($target | path expand --no-symlink)

        systemctl --user enable --now $target
    }    
}

def "main keyd" [] {
    sudo systemctl enable --now keyd
    sudo mkdir -p /etc/keyd
    sudo cp -fv (cfg-path keyd.conf) /etc/keyd/default.conf
    sudo keyd reload
}

#-------------------------------------------------------------------------------

def link [$target, $source = ""] {
    let $source = if ($source | is-empty) {
        $target
    } else {
        $source
    }

    let $source = (cfg-path $source)
    if not ($source | path exists) {
        log warning $"Path `($source)` does not exist; skipping"
        return;
    }

    let $dir = $target | path dirname
    if ($dir | is-symlink) {
        rm -v $dir
    }

    mktrail $target
    ln -sfnT $source $target

    let $target = $target | path expand --no-symlink | shorten-home
    let $source = $source | shorten-home
    print $"($target) -> ($source)"
}

def cfg-path [...$args] {
    [$CONFIG_DIR] | append $args | path join
}
