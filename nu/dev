#!/usr/bin/env nu

use kit *

const $CHECKOUT_DIR = "~/co"

const $REPOS = [
    "~/dot"
    "~/churn"
    "~/src/*"
    $"($CHECKOUT_DIR)/*"
]

# Development
def main [] {
    main open
}

# Open a repo
def "main open" [] {
    ide (main pick)
}

# Pick a repo
def "main pick" [] {
    (main repos) | fzf
}

# List repos
def "main repos" [] {
    $REPOS
        | each { glob $in }
        | flatten
        | each { $in | shorten-home }
        | join-lines
}

# Clone a third-party git repo
def --wrapped clone [...$args] {
    cd $CHECKOUT_DIR
    git clone ...$args
}

#-------------------------------------------------------------------------------

def repo [$dir] {
    [($dir | path expand)]
}

def repos-in [$dir] {
    ls ($dir | path expand) | where type == dir | each { $in.name }
}

def ide [$dir] {
    wm spawn code ($dir | path expand)
}
