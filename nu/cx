#!/usr/bin/env nu

use kit *

# Context
def main [] {
    help main
}

# Cycle main activity
# TODO: Name?
def "main cycle" [] {
    match (wm tag) {
        dev => (wm focus-workspace snd)
        snd => (wm focus-workspace dev)
        _ => {}
    }
}

# Spawn bookmark picker
def "main bookmarks" [] {
    tui pick-url
}

# Spawn repo picker
def "main repos" [] {
    tui pick-repo
}

# Spawn directory picker
def "main explorer" [] {
    tui pick-dir
}

# Open the CWD
def "main dir" [] {
    main term yazi (wm cwd)
}

# Spawn TODO manager
def "main todo" [] {
    tui todo
}

# If there is a URL inside the clipboard, save it as a bookmark
def "main save-clipped-url" [] {
    let $s = (wl-paste)
    if ($s | is-url) {
        tui save-url $s
    } else if ($s | is-empty) {
        notify-send "Clipboard is empty"
    } else {
        notify-send "Clipboard contents is not a URL"
    }
}

# Spawn a browser
def --wrapped "main browser" [...$args] {
    let $project = (wm project)
    if ($project | is-empty) {
        main general-browser ...$args
    } else {
        main project-browser $project ...$args
    }
}

# Spawn general browser
def --wrapped "main general-browser" [...$args] {
    let $app_id = "firefox"
    if ($args | is-empty) {
        let $win = (wm window-with-app-id $app_id)
        if ($win | is-not-empty) {
            wm focus-window $win.id
            return;
        }
    }
    wm spawn $app_id ...$args
}

# Spawn project-specific browser
def --wrapped "main project-browser" [$project, ...$args] {
    let $app_id = "qutebrowser." + $project
    if ($args | is-empty) {
        let $win = (wm window-with-app-id $app_id)
        if ($win | is-not-empty) {
            wm focus-window $win.id
            return;
        }
    }
    let $profile_dir = (data-path "qutebrowser-profiles" $project)
    let $config_file = (config-path "qutebrowser" "config.py")
    (wm spawn qutebrowser
        --basedir $profile_dir
        --config-py $config_file
        --desktop-file-name $app_id
        ...$args
    )
}

# Spawn a terminal and optionally run a command inside of it
def --wrapped "main term" [...$cmd] {
    footclient -D (wm cwd) ...$cmd
}

# If the focused window is a terminal, close it and spawn another term in its place
def "main respawn-term" [] {
    let $w = (wm focused-window)
    if ($w | is-not-empty) and $w.app_id == "footclient" {
        wm spawn footclient -D (wm cwd)
        wm close-window $w.id
    }
}
